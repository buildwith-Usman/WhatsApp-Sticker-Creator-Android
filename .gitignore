# =============================================================================
# Android .gitignore
# =============================================================================

# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
#  Uncomment the following line in case you need and you don't have the release build type files in your version control
#release/

# Gradle files
.gradle/
build/
**/build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ IDEA / Android Studio files
.idea/
*.iml
*.ipr
*.iws
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/asLocal.xml
.idea/libraries
.idea/caches/
.idea/navEditor.xml
.idea/deploymentTargetDropDown.xml

# Keystore files
# UNCOMMENT THE FOLLOWING LINE IF YOU DO NOT WANT YOUR SIGNING KEY TO BE UPLOADED TO VERSION CONTROL
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (e.g. Firebase configuration)
google-services.json

# Fabric (Crashlytics) configuration
fabric.properties

# fastlane
#
# It is recommended to not store the screenshots in the git repo.
# Instead, use fastlane to re-generate the screenshots whenever they are needed.
# For more information about the recommended setup visit:
# https://docs.fastlane.tools/best-practices/source-control/

fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md

# Version control
vcs.xml

# Lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/

# macOS system files
.DS_Store
.DS_Store?
._*
.Spotlight-V8
.Trashes
ehthumbs.db
Thumbs.db

# Windows system files
desktop.ini

# Linux system files
*~

# Compiled source
*.com
*.exe
*.o
*.so

# Packages
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Test results
test-results/

# ktlint
.ktlint

# Detekt
.detekt/

# Coverage reports
coverage/
*.lcov

# Release outputs (keep output-metadata.json for reference if needed)
app/release/
